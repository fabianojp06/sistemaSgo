generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Alinhado a DC_EP084_24 + requisitos/RN_AUTH_Clerk_BancoProprio.md
// Senha, hash e sessão são responsabilidade do Clerk — não modelados aqui.
enum StatusUsuario {
  ATIVO
  INATIVO
}

enum TipoOperacao {
  LOGIN_SUCESSO
  LOGIN_FALHA
  LOGOFF
  BLOQUEIO_AUTOMATICO
  ACESSO_SIMULTANEO
}

model Usuario {
  id                     String        @id @default(uuid())
  clerkUserId            String        @unique
  tenantId               String
  nomeCompleto           String
  email                  String        @unique
  status                 StatusUsuario @default(ATIVO)
  bloqueado              Boolean       @default(false)
  contadorFalhas         Int           @default(0)
  trocarSenhaObrigatoria Boolean       @default(false)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  historicoOperacoes HistoricoOperacao[]
  perfis             UsuarioPerfil[]

  @@index([tenantId])
}

// Catálogo global de módulos do sistema — não pertence a nenhum tenant específico [ADR-001].
model Modulo {
  id     String @id @default(uuid())
  chave  String @unique // ex: "dotacoes", "empenhos"
  nome   String
  ativo  Boolean @default(true) // CA-01.03.03 — inativo é omitido do menu para todos os tenants

  funcionalidades Funcionalidade[]
}

model Funcionalidade {
  id       String  @id @default(uuid())
  moduloId String
  modulo   Modulo  @relation(fields: [moduloId], references: [id])
  chave    String  // ex: "empenhos.criar"
  nome     String
  ativo    Boolean @default(true)

  perfis PerfilFuncionalidade[]

  @@unique([moduloId, chave])
}

// Perfis são definidos por tenant [ADR-001] — RN0027/RN0030 pressupõem permissão por perfil, não por usuário.
model Perfil {
  id       String @id @default(uuid())
  tenantId String
  nome     String

  permissoes PerfilFuncionalidade[]
  usuarios   UsuarioPerfil[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model PerfilFuncionalidade {
  perfilId         String
  perfil           Perfil         @relation(fields: [perfilId], references: [id])
  funcionalidadeId String
  funcionalidade   Funcionalidade @relation(fields: [funcionalidadeId], references: [id])

  @@id([perfilId, funcionalidadeId])
}

model UsuarioPerfil {
  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  perfilId  String
  perfil    Perfil  @relation(fields: [perfilId], references: [id])
  tenantId  String // redundante de propósito — nunca confiar em join solto pra isolar tenant

  @@id([usuarioId, perfilId])
  @@index([tenantId])
}

// Append-only — nenhuma UPDATE/DELETE deve ser executada nesta tabela [RNF0006]
model HistoricoOperacao {
  id                  String       @id @default(uuid())
  tenantId            String
  usuarioId           String?
  usuario             Usuario?     @relation(fields: [usuarioId], references: [id])
  clerkSessionId      String?
  tipoOperacao         TipoOperacao
  descricao           String
  ipEstacao           String?
  quantidadeTentativas Int?
  dadosSerializados   Json?
  dataHoraEvento      DateTime     @default(now())

  @@index([tenantId])
  @@index([usuarioId])
}

// Parâmetros globais do sistema referenciados pelo módulo de autenticação [DC_EP084_24 §7]
model ParametroSistema {
  tenantId              String  @id
  limiteTentativasLogin Int     @default(5)
  flagManutencao        Boolean @default(false)
}
